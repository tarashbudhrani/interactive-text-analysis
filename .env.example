# Square POS — https://developer.squareup.com/apps
SQUARE_ACCESS_TOKEN=
# Use sandbox or production (token must match the environment)
SQUARE_ENVIRONMENT=sandbox

# Slack Incoming Webhook — https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
# Send a second Slack message with 7d/30d sales totals and top movers (set 0 for reorder-only)
SLACK_ENABLE_SALES_METRICS=1

# Incremental pipeline (recommended for CI with a cached DuckDB — see README)
# SKIP_SQUARE_RELOAD_IF_UNCHANGED=1
# SKIP_DBT_IF_RAW_UNCHANGED=1

# Optional: merge CSV quantities into Square inventory after API sync (sku + quantity columns)
# MERGE_INVENTORY_CSV=data/uploads/inventory_adjustments.csv

# Phase 2 macro feeds (only when running: python run_pipeline.py --with-extended-macro-ingest)
# CENSUS_API_KEY=
# BLS_API_KEY=
